# ===== Input Types for Mutations =====

# ----- Administration Inputs -----
input DepartmentInput {
    name: String!
    code: String!
    hodId: ID
    vision: String
    mission: String
    establishedYear: Int
    accreditationStatus: String
    budgetAllocated: BigDecimal
    email: String
    phone: String
    officeLocation: String
    website: String
}

input ProgramInput {
    name: String!
    code: String!
    departmentId: ID!
    durationYears: Int!
    degreeType: String!
    coordinatorId: ID
    totalIntake: Int
    eligibilityCriteria: String
    accreditationStatus: String
    accreditationValidUntil: Date
    programLearningOutcomes: String
    curriculumVersion: String
}

input CourseInput {
    name: String!
    code: String!
    programId: ID!
    credits: Int!
    courseType: String!
    category: String
    prerequisites: String
    corequisites: String
    teachingMethodology: String
    evaluationScheme: String
    maxStudents: Int
}

input AcademicYearInput {
    name: String!
    startDate: Date!
    endDate: Date!
    active: Boolean!
}

input SemesterInput {
    name: String!
    semesterNumber: Int!
    academicYearId: ID!
    startDate: Date
    endDate: Date
}

input CalendarEventInput {
    title: String!
    description: String
    eventDate: Date!
    endDate: Date
    eventType: String!
    category: String
    isRecurring: Boolean
    academicYearId: ID
}

input CourseFeedbackInput {
    studentId: ID!
    courseId: ID!
    semesterId: ID!
    teachingRating: Int!
    contentRating: Int!
    labRating: Int
    overallRating: Int!
    comments: String
    anonymous: Boolean!
}

# ----- Student Inputs -----
input StudentProfileInput {
    keycloakId: String!
    enrollmentNumber: String!
    firstName: String!
    lastName: String!
    email: String!
    phone: String
    dateOfBirth: Date
    gender: String
    bloodGroup: String
    nationality: String
    category: String
    religion: String
    aadhaarNumber: String
    photoUrl: String
    emergencyContactName: String
    emergencyContactPhone: String
    medicalConditions: String
    permanentAddress: String
    correspondenceAddress: String
    programId: ID!
    departmentId: ID!
    currentSemester: Int!
    admissionDate: Date!
    status: String
}

input StudentFilterInput {
    departmentId: ID
    programId: ID
    semester: Int
    status: String
    searchTerm: String
}

input StudentEnrollmentInput {
    studentId: ID!
    courseId: ID!
    semesterId: ID!
    labBatchGroup: String
    enrollmentDate: Date!
    status: String
}

input AdmissionInput {
    studentId: ID!
    applicationNumber: String!
    programId: ID!
    admissionDate: Date!
    admissionType: String!
    entranceExamName: String
    entranceExamRank: Int
    entranceExamScore: BigDecimal
    meritRank: Int
    quotaCategory: String
    status: String!
    remarks: String
}

input AdmissionFilterInput {
    programId: ID
    status: String
    admissionType: String
    academicYear: String
}

input GpaRecordInput {
    studentId: ID!
    semesterId: ID!
    semesterGpa: BigDecimal!
    cgpa: BigDecimal!
    totalCredits: Int!
    earnedCredits: Int!
    labComponentGpa: BigDecimal
    calculationDate: Date!
    status: String
}

input ScholarshipInput {
    studentId: ID!
    name: String!
    amount: BigDecimal!
    scholarshipType: String!
    provider: String
    awardedDate: Date!
    expiryDate: Date
    renewalCriteria: String
    status: String!
    remarks: String
}

input StudentGuardianInput {
    studentId: ID!
    name: String!
    relation: String!
    phone: String!
    email: String
    occupation: String
    annualIncome: BigDecimal
    address: String
    isPrimary: Boolean!
}

input StudentDocumentInput {
    studentId: ID!
    documentType: String!
    documentName: String!
    fileUrl: String!
    uploadDate: Date!
    remarks: String
}

input StudentAchievementInput {
    studentId: ID!
    title: String!
    category: String!
    level: String!
    date: Date!
    description: String
    certificateUrl: String
    awardedBy: String
}

input StudentPreviousEducationInput {
    studentId: ID!
    level: String!
    boardOrUniversity: String!
    institutionName: String!
    yearOfPassing: Int!
    percentage: BigDecimal!
    subjects: String
    certificateUrl: String
}

input DisciplinaryRecordInput {
    studentId: ID!
    incidentDate: Date!
    category: String!
    description: String!
    actionTaken: String
    severity: String!
    reportedBy: String!
    status: String!
    resolution: String
}

input StudentMentorInput {
    studentId: ID!
    facultyId: ID!
    semesterId: ID!
    assignedDate: Date!
    notes: String
}

input BacklogInput {
    studentId: ID!
    courseId: ID!
    semesterId: ID!
    attemptNumber: Int!
    originalMarks: BigDecimal
    status: String!
    clearedDate: Date
    clearedMarks: BigDecimal
}

# ----- Faculty Inputs -----
input FacultyProfileInput {
    keycloakId: String!
