}

# ----- Lab Inputs -----
input LabInput {
    name: String!
    code: String!
    labTypeId: ID!
    departmentId: ID!
    location: String
    capacity: Int!
    status: String
}

input LabTypeInput {
    name: String!
    description: String
}

input EquipmentInput {
    labId: ID!
    name: String!
    modelNumber: String
    serialNumber: String
